# Copy this file to `.env` and fill in the values.

# Required — Postgres connection string used by the api-server and db package.
DATABASE_URL=postgres://user:password@localhost:5432/datacanvas

# Optional — defaults shown. Uncomment to override.
# PORT=8080                                  # api-server port
# API_PORT=8080                              # used by the frontend to build API_PROXY_TARGET
# API_PROXY_TARGET=http://localhost:8080     # frontend dev-server proxy target for /api
# BASE_PATH=/                                # frontend base path (for subpath deploys)
